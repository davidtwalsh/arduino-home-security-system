                    </mxGeometry>
                </mxCell>
                <mxCell id="16" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Summary&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Arduino Sensor Components&lt;/b&gt; send sensor data to the Backend Service via serial communication (I.e. a LD2410 arduino system notifies the python app on human movement detected)&lt;/li&gt;&lt;li&gt;The &lt;b&gt;Backend Service&lt;/b&gt; receives sensor information from the Arduino Sensor Components and sends commands to Arduino Actuator Components (I.e. The Backend Service recieves human movement detected info and tells an arduino component to play an alarm)&lt;/li&gt;&lt;li&gt;The &lt;b&gt;Arduino Actuator Components&lt;/b&gt; receive a &quot;begin&quot; command from the Backend Service and affect the environment (I.e. play a sound, or flash a light)&lt;/li&gt;&lt;li&gt;The &lt;b&gt;React Dashboard&lt;/b&gt; allows for configuration of the Backend Service realtime over REST APIs&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="5" y="360" width="580" height="210" as="geometry"/>
                </mxCell>
