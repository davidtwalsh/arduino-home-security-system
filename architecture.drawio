                <mxCell id="9" value="Serial&lt;div&gt;WIFI&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="8">
                    <mxGeometry x="0.0462" y="-1" relative="1" as="geometry">
